{
  "name": "pg-mvp-2",
  "version": "0.0.0",
  "private": true,
  "description": "Pitch Genius Buyer Readiness MVP",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @pg/db generate",
    "db:migrate": "pnpm --filter @pg/db migrate",
    "db:seed": "pnpm --filter @pg/db seed",
    "db:seed:auth": "pnpm --filter @pg/api seed:demo",
    "db:studio": "pnpm --filter @pg/db studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
