# Database
DATABASE_URL=postgres://pg:pg@localhost:5432/pg_mvp

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Live Co-pilot latency-validation harness (apps/desktop-copilot/latency-tests)
# Real provider calls only — the harness refuses to run a step whose key is missing.
OPENAI_API_KEY=sk-...
PERPLEXITY_API_KEY=pplx-...
DEEPGRAM_API_KEY=...
# Optional: stable label for this machine in the results (defaults to hostname-platform-arch)
LATENCY_MACHINE_ID=

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-random-32-byte-secret
BETTER_AUTH_URL=http://localhost:3000

# Service URLs
API_URL=http://localhost:3000
WEB_URL=http://localhost:5173

# Web (Vite exposes VITE_ prefixed vars to the browser)
VITE_API_URL=http://localhost:3000

# API
PORT=3000
NODE_ENV=development
